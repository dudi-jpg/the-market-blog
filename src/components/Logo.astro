---
interface Props {
  light?: boolean; // light=true for dark backgrounds (footer)
  size?: number; // wordmark font-size in px
}
const { light = false, size = 30 } = Astro.props;
---

<span class:list={['logo', light && 'logo--light']} style={`--logo-size:${size}px`} dir="ltr">
  <svg class="logo-mark" viewBox="0 0 46 40" width={Math.round(size * 1.2)} height={size} aria-hidden="true">
    <!-- ascending bars -->
    <rect x="1" y="26" width="7" height="13" rx="1.5" fill="currentColor" opacity="0.3" />
    <rect x="11" y="20" width="7" height="19" rx="1.5" fill="currentColor" opacity="0.5" />
    <rect x="21" y="13" width="7" height="26" rx="1.5" fill="currentColor" opacity="0.75" />
    <!-- rising trend line + arrowhead (accent) -->
    <path d="M3 24 L15 17 L24 21 L42 6" fill="none" stroke="var(--accent)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
    <path d="M42 6 L34.5 6 M42 6 L42 13" fill="none" stroke="var(--accent)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
  <span class="logo-word"><span class="w-the">The</span><span class="w-market">Market</span></span>
</span>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 11px;
    color: var(--ink);
  }
  .logo-mark {
    flex: none;
  }
  .logo-word {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--logo-size);
    line-height: 1;
    letter-spacing: -0.025em;
    display: inline-flex;
    gap: 0.16em;
  }
  .w-the {
    color: var(--muted);
    font-weight: 600;
  }
  .w-market {
    color: var(--ink);
  }
  .logo--light .w-the {
    color: rgba(255, 255, 255, 0.6);
  }
  .logo--light .w-market {
    color: #fff;
  }
</style>
