---
// סקירת שווקים חיה (TradingView) — גרסת סיידבר (ווידג'ט בלבד).
const config = {
  colorTheme: 'light',
  dateRange: '12M',
  showChart: true,
  locale: 'he_IL',
  isTransparent: true,
  showSymbolLogo: true,
  width: '100%',
  height: 420,
  tabs: [
    {
      title: 'מדדים',
      symbols: [
        { s: 'TASE:TA35', d: 'ת"א 35' },
        { s: 'TASE:TA125', d: 'ת"א 125' },
        { s: 'NASDAQ:IXIC', d: 'נאסד״ק' },
        { s: 'SP:SPX', d: 'S&P 500' },
      ],
    },
    {
      title: 'מטבעות',
      symbols: [
        { s: 'FX_IDC:USDILS', d: 'דולר/שקל' },
        { s: 'FX_IDC:EURILS', d: 'יורו/שקל' },
      ],
    },
    {
      title: 'קריפטו',
      symbols: [
        { s: 'BINANCE:BTCUSDT', d: 'ביטקוין' },
        { s: 'BINANCE:ETHUSDT', d: 'את׳ריום' },
      ],
    },
  ],
};
const snippet = `<div class="tradingview-widget-container"><div class="tradingview-widget-container__widget"></div><script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-market-overview.js" async>${JSON.stringify(config)}</script></div>`;
---

<div class="tv-embed"><Fragment set:html={snippet} /></div>

<style>
  .tv-embed {
    min-height: 420px;
  }
</style>
